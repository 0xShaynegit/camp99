{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "camp99",
  "compatibility_date": "2026-05-11",

  "assets": {
    "directory": "./",
    "include": ["**/*.html", "**/*.css", "**/*.js", "**/*.json", "**/*.xml", "**/*.webp", "**/*.png", "**/*.svg", "**/*.ttf", "**/*.woff", "**/*.woff2", "**/*.txt"]
  }
}
